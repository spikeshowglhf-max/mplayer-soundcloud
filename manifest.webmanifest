{
  "name": "Mplayer SoundCloud",
  "short_name": "Mplayer",
  "description": "Кастомный музыкальный плеер для GitHub Pages с очередью и SoundCloud widget API.",
  "lang": "ru",
  "start_url": "./",
  "scope": "./",
