{
  "name": "mplayer-soundcloud-desktop",
  "productName": "Mplayer SoundCloud",
  "version": "1.1.0",
  "description": "Кастомный SoundCloud-плеер как настольное приложение для Windows.",
  "main": "electron/main.js",
  "author": "vlads",
  "license": "MIT",
  "scripts": {
    "prepare:web": "node scripts/prepare-web-assets.mjs",
    "start": "electron .",
    "cap:copy": "npm run prepare:web && npx cap copy",
    "cap:sync": "npm run prepare:web && npx cap sync",
    "android:add": "npx cap add android",
    "dist:dir": "electron-builder --win dir",
    "dist:portable": "electron-builder --win portable",
    "dist:installer": "electron-builder --win nsis",
    "android:build:debug": "npm run prepare:web && npx cap sync android && cd android && gradlew.bat assembleDebug"
  },
  "build": {
    "appId": "com.vlads.mplayer",
    "productName": "Mplayer SoundCloud",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "assets/**/*",
      "electron/**/*",
      "index.html",
      "manifest.webmanifest",
      "script.js",
      "styles.css",
      "sw.js",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "asar": true,
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.15.3"
  }
}
